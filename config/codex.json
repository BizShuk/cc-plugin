{
  "skillListingBudgetFraction": 0.01,
  "env": {
    "_____proxy": "_____",
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:8317",
    "_____prompt": "_____",
    "_____model": "_____",
    "ANTHROPIC_MODEL": "gpt-5.5",
    "ANTHROPIC_DEFAULT_FABLE_MODEL": "gpt-5.6-sol",
    "ANTHROPIC_DEFAULT_FABLE_MODEL_NAME": "gpt-5.6-sol",
    "ANTHROPIC_DEFAULT_FABLE_MODEL_DESCRIPTION": "gpt-5.6-sol",
    "ANTHROPIC_DEFAULT_FABLE_MODEL_SUPPORTED_CAPABILITIES": "effort,xhigh_effort,max_effort,thinking,adaptive_thinking,interleaved_thinking",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "gpt-5.5",
    "ANTHROPIC_DEFAULT_OPUS_MODEL_NAME": "gpt-5.5",
    "ANTHROPIC_DEFAULT_OPUS_MODEL_DESCRIPTION": "gpt-5.5",
    "ANTHROPIC_DEFAULT_OPUS_MODEL_SUPPORTED_CAPABILITIES": "effort,xhigh_effort,max_effort,thinking,adaptive_thinking,interleaved_thinking",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "gpt-5.6-terra",
    "ANTHROPIC_DEFAULT_SONNET_MODEL_NAME": "gpt-5.6-terra",
    "ANTHROPIC_DEFAULT_SONNET_MODEL_DESCRIPTION": "gpt-5.6-terra",
    "ANTHROPIC_DEFAULT_SONNET_MODEL_SUPPORTED_CAPABILITIES": "effort,xhigh_effort,max_effort,thinking,adaptive_thinking,interleaved_thinking",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "gpt-5.6-luna",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME": "gpt-5.6-luna",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL_DESCRIPTION": "gpt-5.6-luna",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL_SUPPORTED_CAPABILITIES": "effort,xhigh_effort,max_effort,thinking,adaptive_thinking,interleaved_thinking",
    "_____agent": "_____",
    "CLAUDE_CODE_SUBAGENT_MODEL": "gpt-5.5",
    "_____extra": "_____",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY": "3",
    "ENABLE_TOOL_SEARCH": "false"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(df:*)",
      "Bash(du:*)",
      "Bash(mkdir:*)",
      "Bash(head:*)",
      "Bash(find:*)",
      "Bash(sed:*)",
      "Bash(grep:*)",
      "Bash(go:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(rm:*)",
      "Bash(git:*)",
      "Bash(cat:*)",
      "Bash(chmod +x:*)",
      "Read(//Users/shuk/.gbrain/**)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(**/secrets/**)",
      "Read(~/.claude/settings.json)",
      "Edit(./.git)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Read(.env*)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": []
  },
  "worktree": {},
  "enableWorkflows": true,
  "defaultShell": "bash",
  "allowedHttpHookUrls": [
    "http://localhost:*"
  ],
  "httpHookAllowedEnvVars": [
    "MY_TOKEN",
    "HOOK_SECRET"
  ],
  "statusLine": {
    "type": "command",
    "command": "npx ccstatusline",
    "padding": 0
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "claude-notifications-go@claude-notifications-go": true
  },
  "extraKnownMarketplaces": {
    "claude-notifications-go": {
      "source": {
        "source": "github",
        "repo": "777genius/claude-notifications-go"
      }
    },
    "shuk-cc-plugin": {
      "source": {
        "source": "directory",
        "path": "/Users/bytedance/projects/cc-plugin"
      }
    }
  },
  "syntaxHighlightingDisabled": false,
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "fastModePerSessionOptIn": true,
  "promptSuggestionEnabled": false,
  "autoUpdatesChannel": "latest",
  "minimumVersion": "2.1.150",
  "plansDirectory": "./plans",
  "tui": "fullscreen",
  "voice": {
    "enabled": true
  },
  "prefersReducedMotion": true,
  "autoMemoryEnabled": true,
  "autoMemoryDirectory": "~/memory",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "dark-ansi",
  "verbose": false,
  "preferredNotifChannel": "auto",
  "teammateMode": "in-process",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true
}
