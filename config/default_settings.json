{
    "state": {
        "db_path": "~/.distiller/state.db"
    },
    "retention": {
        "max_age_days": 30
    },
    "llm": {
        "model": "qwen2.5",
        "host": "http://localhost:11434"
    },
    "sources": {
        "claude_mem": {
            "db_path": "~/.claude-mem/claude-mem.db",
            "table": "observations",
            "id_col": "id",
            "ts_col": "created_at_epoch",
            "text_col": "text"
        },
        "gbrain_working": {
            "root": "~/brain/working"
        }
    },
    "stores": {
        "agentmemory": {
            "url": "http://localhost:3111/agentmemory/remember"
        },
        "mempalace": {
            "wing": "main",
            "temp_dir": "/tmp/mempalace-temp"
        }
    }
}