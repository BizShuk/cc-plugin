{
    "env": {
        "_____proxy": "_____",
        "ANTHROPIC_BASE_URL": "https://llmbox.bytedance.net/",
        "API_TIMEOUT_MS": "3000000",
        "_____prompt": "_____",
        "CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "1",
        "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75",
        "_____model": "_____",
        "ANTHROPIC_MODEL": "minimax-m3",
        "CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY": "1",
        "ANTHROPIC_DEFAULT_FABLE_MODEL": "deepseek-v4-pro[1m]",
        "ANTHROPIC_DEFAULT_FABLE_MODEL_NAME": "deepseek-v4-pro[1m]",
        "ANTHROPIC_DEFAULT_FABLE_MODEL_DESCRIPTION": "deepseek-v4-pro[1m]",
        "ANTHROPIC_DEFAULT_FABLE_MODEL_SUPPORTED_CAPABILITIES": "effort,xhigh_effort,max_effort,thinking,adaptive_thinking,interleaved_thinking",
        "ANTHROPIC_DEFAULT_OPUS_MODEL": "minimax-m3",
        "ANTHROPIC_DEFAULT_OPUS_MODEL_NAME": "minimax-m3",
        "ANTHROPIC_DEFAULT_OPUS_MODEL_DESCRIPTION": "minimax-m3",
        "ANTHROPIC_DEFAULT_OPUS_MODEL_SUPPORTED_CAPABILITIES": "effort,xhigh_effort,max_effort,thinking,adaptive_thinking,interleaved_thinking",
        "ANTHROPIC_DEFAULT_SONNET_MODEL": "glm-5.2",
        "ANTHROPIC_DEFAULT_SONNET_MODEL_NAME": "glm-5.2",
        "ANTHROPIC_DEFAULT_SONNET_MODEL_DESCRIPTION": "glm-5.2",
        "ANTHROPIC_DEFAULT_SONNET_MODEL_SUPPORTED_CAPABILITIES": "effort,xhigh_effort,max_effort,thinking,adaptive_thinking,interleaved_thinking",
        "ANTHROPIC_DEFAULT_HAIKU_MODEL": "minimax-m2.7",
        "ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME": "minimax-m2.7",
        "ANTHROPIC_DEFAULT_HAIKU_MODEL_DESCRIPTION": "minimax-m2.7",
        "ANTHROPIC_DEFAULT_HAIKU_MODEL_SUPPORTED_CAPABILITIES": "effort,xhigh_effort,max_effort,thinking,adaptive_thinking,interleaved_thinking",
        "ANTHROPIC_CUSTOM_MODEL_OPTION": "gpt-5.3-codex",
        "ANTHROPIC_CUSTOM_MODEL_OPTION_NAME": "gpt-5.3-codex",
        "ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION": "gpt-5.3-codex",
        "ANTHROPIC_CUSTOM_MODEL_SUPPORTED_CAPABILITIES": "effort,xhigh_effort,max_effort,thinking,adaptive_thinking,interleaved_thinking",
        "_____agent": "_____",
        "CLAUDE_CODE_SUBAGENT_MODEL": "minimax-m3",
        "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
        "CLAUDE_CODE_DISABLE_FAST_MODE": "1",
        "_____extra": "_____",
        "ENABLE_LSP_TOOL": "1",
        "DISABLE_TELEMETRY": "1",
        "DISABLE_AUTOUPDATER": "1"
    },
    "permissions": {
        "allow": [
            "Bash(ls:*)",
            "Bash(df:*)",
            "Bash(du:*)",
            "Bash(mkdir:*)",
            "Bash(head:*)",
            "Bash(find:*)",
            "Bash(sed:*)",
            "Bash(grep:*)",
            "Bash(go:*)",
            "Bash(python:*)",
            "Bash(python3:*)",
            "Bash(rm:*)",
            "Bash(git:*)",
            "Bash(cat:*)",
            "Bash(chmod +x:*)",
            "Read(//Users/shuk/.gbrain/**)"
        ],
        "deny": [
            "Read(~/.ssh/**)",
            "Read(~/.aws/**)",
            "Read(**/secrets/**)",
            "Read(~/.claude/settings.json)",
            "Edit(**/.git)"
        ],
        "ask": [
            "Bash(git push:*)",
            "Read(.env*)"
        ],
        "defaultMode": "bypassPermissions",
        "additionalDirectories": []
    },
    "worktree": {
        "baseRef": "fresh"
    },
    "defaultShell": "bash",
    "allowedHttpHookUrls": [
        "http://localhost:*"
    ],
    "httpHookAllowedEnvVars": [
        "MY_TOKEN",
        "HOOK_SECRET"
    ],
    "CLAUDE_CODE_DISABLE_FAST_MODE": "1",
    "skillListingBudgetFraction": 0.02,
    "statusLine": {
        "type": "command",
        "command": "npx ccstatusline",
        "padding": 0,
        "refreshInterval": 10
    },
    "extraKnownMarketplaces": {},
    "syntaxHighlightingDisabled": false,
    "alwaysThinkingEnabled": true,
    "effortLevel": "xhigh",
    "fastModePerSessionOptIn": true,
    "promptSuggestionEnabled": false,
    "autoUpdatesChannel": "latest",
    "minimumVersion": "2.1.140",
    "plansDirectory": "./plans",
    "voice": {
        "enabled": false,
        "mode": "hold"
    },
    "prefersReducedMotion": true,
    "autoMemoryEnabled": false,
    "autoMemoryDirectory": "~/memory",
    "theme": "dark-ansi",
    "verbose": false,
    "preferredNotifChannel": "auto",
    "teammateMode": "in-process",
    "enabledPlugins": {
        "claude-mem@thedotmack": true,
        "gopls-lsp@claude-plugins-official": true
    }
}